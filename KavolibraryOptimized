                    if colorpicker then
                        local x = math.clamp(ms.X - rgb.AbsolutePosition.X, 0, rgb.AbsoluteSize.X)
                        local y = math.clamp(ms.Y - rgb.AbsolutePosition.Y, 0, rgb.AbsoluteSize.Y)
                        x = x / rgb.AbsoluteSize.X
                        y = y / rgb.AbsoluteSize.Y
                        cursor.Position = UDim2.new(x, -cursor.AbsoluteSize.X/2, y, -cursor.AbsoluteSize.Y/2)
                        color = {1-x, 1-y, color[3]}
                        local realcolor = Color3.fromHSV(color[1], color[2], color[3])
                        colorCurrent.BackgroundColor3 = realcolor
                        callback(realcolor)
                    end
                    if darknesss then
                        local y = math.clamp(ms.Y - darkness.AbsolutePosition.Y, 0, darkness.AbsoluteSize.Y)
                        y = y / darkness.AbsoluteSize.Y
                        cursor2.Position = UDim2.new(0.5, 0, y, -cursor2.AbsoluteSize.Y/2)
                        cursor2.ImageColor3 = Color3.fromHSV(0, 0, y)
                        color = {color[1], color[2], 1-y}
                        local realcolor = Color3.fromHSV(color[1], color[2], color[3])
                        colorCurrent.BackgroundColor3 = realcolor
                        callback(realcolor)
                    end
                end

                local function setcolor(tbl)
                    local cx, cy = cursor.AbsoluteSize.X/2, cursor.AbsoluteSize.Y/2
                    color = {tbl[1], tbl[2], tbl[3]}
                    cursor.Position  = UDim2.new(color[1], -cx, color[2]-1, -cy)
                    cursor2.Position = UDim2.new(0.5, 0, color[3]-1, -cy)
                    colorCurrent.BackgroundColor3 = Color3.fromHSV(color[1], color[2], color[3])
                end

                local function setrgbcolor(tbl)
                    local cx, cy = cursor.AbsoluteSize.X/2, cursor.AbsoluteSize.Y/2
                    color = {tbl[1], tbl[2], color[3]}
                    cursor.Position = UDim2.new(color[1], -cx, color[2]-1, -cy)
                    local realcolor = Color3.fromHSV(color[1], color[2], color[3])
                    colorCurrent.BackgroundColor3 = realcolor
                    callback(realcolor)
                end

                local function togglerainbow()
                    if rainbow then
                        Utility:TweenObject(toggleEnabled, {ImageTransparency = 1}, 0.1, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
                        rainbow = false
                        rainbowconn:Disconnect()
                    else
                        Utility:TweenObject(toggleEnabled, {ImageTransparency = 0}, 0.1, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
                        rainbow = true
                        rainbowconn = rs.RenderStepped:Connect(function()
                            setrgbcolor({zigzag(counter), 1, 1})
                            counter = counter + 0.01
                        end)
                    end
                end

                onrainbow.MouseButton1Click:Connect(togglerainbow)
                ms.Move:Connect(cp)
                rgb.MouseButton1Down:Connect(function() colorpicker = true end)
                darkness.MouseButton1Down:Connect(function() darknesss = true end)
                UserInput.InputEnded:Connect(function(inp)
