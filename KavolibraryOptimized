local Utility       = {}
local themeWatchers = {}   -- { [obj] = { prop, getValueFn } }

-- ── Theme sync (replaces every `while wait() do` polling loop) ───────────────
-- Each element registers watchers once; a single Heartbeat drives all of them.
local function watchTheme(obj, prop, getValueFn)
    themeWatchers[obj] = { prop = prop, fn = getValueFn }
end

RunService.Heartbeat:Connect(function()
    for obj, w in next, themeWatchers do
        if obj and obj.Parent then
            obj[w.prop] = w.fn()
        else
            themeWatchers[obj] = nil   -- clean up destroyed objects
        end
    end
end)

-- ── Shared helpers ───────────────────────────────────────────────────────────

-- Shift an existing Color3's 0–1 channels by integer deltas.
local function shiftColor(c3, dr, dg, db)
    return Color3.fromRGB(
        math.clamp(c3.R * 255 + dr, 0, 255),
        math.clamp(c3.G * 255 + dg, 0, 255),
        math.clamp(c3.B * 255 + db, 0, 255)
    )
end

-- Tween helper (unchanged API).
function Utility:TweenObject(obj, properties, duration, ...)
    TweenService:Create(obj, tweeninfo(duration, ...), properties):Play()
end

-- Ripple / sample animation (was copy-pasted ~12 times).
local function playRipple(sample, btn, ms)
    local c = sample:Clone()
    c.Parent = btn
    local x = ms.X - c.AbsolutePosition.X
    local y = ms.Y - c.AbsolutePosition.Y
    c.Position = UDim2.new(0, x, 0, y)
    local len  = 0.35
    local size = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 1.5
    c:TweenSizeAndPosition(
        UDim2.new(0, size, 0, size),
        UDim2.new(0.5, -size/2, 0.5, -size/2),
        "Out", "Quad", len, true, nil
    )
    for _ = 1, 10 do
        c.ImageTransparency = c.ImageTransparency + 0.05
        wait(len / 12)
    end
    c:Destroy()
end

-- Hover highlight (was copy-pasted for every element type).
local function hookHover(btn, themeRef, focusing)
    local hovering = false
    local tiInfo = tweeninfo(0.1, Enum.EasingStyle.Linear, Enum.EasingDirection.In)
    btn.MouseEnter:Connect(function()
        if not focusing() then
            TweenService:Create(btn, tiInfo, {
                BackgroundColor3 = shiftColor(themeRef().ElementColor, 8, 9, 10)
            }):Play()
            hovering = true
        end
    end)
    btn.MouseLeave:Connect(function()
        if not focusing() then
            TweenService:Create(btn, tiInfo, {
                BackgroundColor3 = themeRef().ElementColor
            }):Play()
            hovering = false
        end
    end)
    -- Keep bg in sync while not hovering (replaces the per-element coroutine)
    watchTheme(btn, "BackgroundColor3", function()
        if hovering then return btn.BackgroundColor3 end
        return themeRef().ElementColor
    end)
    return function() return hovering end
end

-- ViewInfo tooltip (was copy-pasted for every element type).
local function hookViewInfo(viewInfo, moreInfo, btn, blurFrame, infoContainer,
                             themeRef, focusingRef, setFocusing, viewDeRef, setViewDe)
    viewInfo.MouseButton1Click:Connect(function()
        if viewDeRef() then return end
        setViewDe(true)
        setFocusing(true)
        for _, v in next, infoContainer:GetChildren() do
            if v ~= moreInfo then
                Utility:TweenObject(v, {Position = UDim2.new(0, 0, 2, 0)}, 0.2)
            end
        end
        Utility:TweenObject(moreInfo,  {Position = UDim2.new(0, 0, 0, 0)}, 0.2)
        Utility:TweenObject(blurFrame, {BackgroundTransparency = 0.5},      0.2)
        Utility:TweenObject(btn,       {BackgroundColor3 = themeRef().ElementColor}, 0.2)
        wait(1.5)
        setFocusing(false)
        Utility:TweenObject(moreInfo,  {Position = UDim2.new(0, 0, 2, 0)}, 0.2)
        Utility:TweenObject(blurFrame, {BackgroundTransparency = 1},        0.2)
        setViewDe(false)
    end)
end

-- Dismiss infoContainer (was copy-pasted in every "else" focusing branch).
local function dismissInfo(infoContainer, blurFrame, setFocusing)
    for _, v in next, infoContainer:GetChildren() do
        Utility:TweenObject(v, {Position = UDim2.new(0, 0, 2, 0)}, 0.2)
    end
    setFocusing(false)
    Utility:TweenObject(blurFrame, {BackgroundTransparency = 1}, 0.2)
end

-- moreInfo background colour (was computed inline ~12 times).
local function moreInfoBG(themeList)
    return shiftColor(themeList.SchemeColor, -14, -17, -13)
end

