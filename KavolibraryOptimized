                function DropFunction:Refresh(newList)
                    newList = newList or {}
                    for _, v in next, dropFrame:GetChildren() do
                        if v.Name == "optionSelect" then v:Destroy() end
                    end
                    for _, v in next, newList do
                        addOption(v)
                    end
                    local targetH = opened and UIListLayout.AbsoluteContentSize.Y or 33
                    dropFrame:TweenSize(UDim2.new(0, 352, 0, targetH), "InOut", "Linear", 0.08, true)
                    wait(0.1)
                    updateSectionFrame()
                    UpdateSize()
                end

                return DropFunction
            end

