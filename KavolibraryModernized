-- Resolve a theme by name or table
local function resolveTheme(input)
    if type(input) == "string" then
        return Themes[input] or Themes.Default
    elseif type(input) == "table" then
        -- Allow partial overrides
        local base = {}
        for k,v in pairs(Themes.Default) do base[k] = v end
        for k,v in pairs(input) do base[k] = v end
        return base
    end
    return Themes.Default
end

-- ── Ripple helper ──────────────────────────────────────────────────────────────
local function ripple(parent, theme)
    local ms   = game.Players.LocalPlayer:GetMouse()
    local rip  = Instance.new("ImageLabel")
    rip.Parent             = parent
    rip.BackgroundTransparency = 1
    rip.Image              = "http://www.roblox.com/asset/?id=4560909609"
    rip.ImageColor3        = theme.Accent
    rip.ImageTransparency  = 0.72
    rip.Size               = UDim2.fromOffset(0, 0)
    local x = ms.X - parent.AbsolutePosition.X
    local y = ms.Y - parent.AbsolutePosition.Y
    rip.Position = UDim2.fromOffset(x, y)
    local sz = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.6
    rip:TweenSizeAndPosition(
        UDim2.fromOffset(sz, sz),
        UDim2.new(0.5, -sz/2, 0.5, -sz/2),
        "Out", "Quad", 0.38, true
    )
    for i = 1, 10 do
        rip.ImageTransparency = rip.ImageTransparency + 0.065
        task.wait(0.38 / 12)
    end
    rip:Destroy()
end

-- ── Corner helper ──────────────────────────────────────────────────────────────
local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color     = color
    s.Thickness = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

