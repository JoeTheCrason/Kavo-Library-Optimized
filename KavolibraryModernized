                -- Info button
                local infoBtn = Instance.new("ImageButton")
                infoBtn.Parent          = el
                infoBtn.BackgroundTransparency = 1
                infoBtn.Position        = UDim2.new(1, -28, 0.5, -10)
                infoBtn.Size            = UDim2.fromOffset(20, 20)
                infoBtn.ZIndex          = 4
                infoBtn.Image           = "rbxassetid://3926305904"
                infoBtn.ImageColor3     = theme.TextMuted
                infoBtn.ImageRectOffset = Vector2.new(764, 764)
                infoBtn.ImageRectSize   = Vector2.new(36, 36)

                -- Hover fx
                local hovering = false
                el.MouseEnter:Connect(function()
                    if not focusing then
                        Tween(el, {BackgroundColor3 = theme.ElementHov}, 0.1)
                        hovering = true
                    end
                end)
                el.MouseLeave:Connect(function()
                    if not focusing then
                        Tween(el, {BackgroundColor3 = theme.Element}, 0.1)
                        hovering = false
                    end
                end)

                task.spawn(function()
                    while task.wait(0) do
                        if not hovering then
                            el.BackgroundColor3 = theme.Element
                        end
                        ic.ImageColor3     = theme.Accent
                        lb.TextColor3      = theme.Text
                        infoBtn.ImageColor3 = theme.TextMuted
                    end
                end)

                return el, ic, lb, infoBtn
            end

            -- ── Button ──────────────────────────────────────────────────────
            function Elements:NewButton(bname, tip, callback)
                bname    = bname or "Button"
                tip      = tip or ""
                callback = callback or function() end

                local el, ic, lb, infoBtn = makeBaseElement(
                    "rbxassetid://3926305904",
                    Vector2.new(84, 204), Vector2.new(36, 36)
                )
                lb.Text = bname

                local tooltip = makeTooltip(tip)
                infoBtn.MouseButton1Click:Connect(function()
