local ConfigName = "KavoModernConfig.json"
local SavedSettings = {}
pcall(function()
    if not pcall(function() readfile(ConfigName) end) then
        writefile(ConfigName, game:GetService("HttpService"):JSONEncode(SavedSettings))
    end
    SavedSettings = game:GetService("HttpService"):JSONDecode(readfile(ConfigName))
end)

-- ── Toggle visibility ──────────────────────────────────────────────────────────
function Kavo:ToggleUI()
    local gui = game.CoreGui:FindFirstChild(LibName)
    if gui then gui.Enabled = not gui.Enabled end
end

