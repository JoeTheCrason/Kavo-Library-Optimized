            -- ── Toggle ──────────────────────────────────────────────────────
            function Elements:NewToggle(tname, tip, callback)
                tname    = tname or "Toggle"
                tip      = tip or ""
                callback = callback or function() end

                local toggled = false
                local el, ic, lb, infoBtn = makeBaseElement(
                    "rbxassetid://3926309567",
                    Vector2.new(628, 420), Vector2.new(48, 48)
                )
                lb.Text = tname

                -- Toggle track
                local Track = Instance.new("Frame")
                Track.Parent          = el
                Track.BackgroundColor3 = theme.Border
                Track.Position        = UDim2.new(1, -54, 0.5, -9)
                Track.Size            = UDim2.fromOffset(34, 18)
                corner(Track, 9)

                local Thumb = Instance.new("Frame")
                Thumb.Parent          = Track
                Thumb.BackgroundColor3 = Color3.new(1, 1, 1)
                Thumb.Position        = UDim2.new(0, 2, 0.5, -7)
                Thumb.Size            = UDim2.fromOffset(14, 14)
                corner(Thumb, 7)

                local function setToggle(state, silent)
                    toggled = state
                    if state then
                        Tween(Track, {BackgroundColor3 = theme.Accent}, 0.18)
                        Tween(Thumb, {Position = UDim2.new(0, 18, 0.5, -7)}, 0.18)
                    else
                        Tween(Track, {BackgroundColor3 = theme.Border}, 0.18)
                        Tween(Thumb, {Position = UDim2.new(0, 2, 0.5, -7)}, 0.18)
                    end
                    if not silent then pcall(callback, state) end
                end

                el.MouseButton1Click:Connect(function()
                    if not focusing then
                        setToggle(not toggled)
                        task.spawn(ripple, el, theme)
                    else
                        Tween(BlurFrame, {BackgroundTransparency = 1}, 0.15)
                        focusing = false
                    end
                end)

                local tooltip = makeTooltip(tip)
                infoBtn.MouseButton1Click:Connect(function() showTooltip(tooltip) end)

                task.spawn(function()
                    while task.wait(0) do
                        Thumb.BackgroundColor3 = Color3.new(1, 1, 1)
                    end
                end)

                syncSizes()
                local TogFn = {}
                function TogFn:UpdateToggle(newText, state)
                    if newText then lb.Text = newText end
                    if state ~= nil then setToggle(state, false) end
                end
                function TogFn:GetState() return toggled end
                return TogFn
            end

            -- ── Slider ──────────────────────────────────────────────────────
            function Elements:NewSlider(sname, tip, maxVal, minVal, defVal, callback)
                sname    = sname or "Slider"
                tip      = tip or ""
                maxVal   = maxVal or 100
                minVal   = minVal or 0
                defVal   = defVal or minVal
                callback = callback or function() end

                local el, ic, lb, infoBtn = makeBaseElement(
                    "rbxassetid://3926307971",
                    Vector2.new(404, 164), Vector2.new(36, 36)
                )
                lb.Text = sname
                lb.Size = UDim2.new(0.38, 0, 0, 16)

                local ValLabel = Instance.new("TextLabel")
                ValLabel.Parent          = el
                ValLabel.BackgroundTransparency = 1
                ValLabel.Position        = UDim2.new(0.38, 0, 0.5, -8)
                ValLabel.Size            = UDim2.fromOffset(36, 16)
                ValLabel.Font            = Enum.Font.GothamMedium
                ValLabel.Text            = tostring(defVal)
                ValLabel.TextColor3      = theme.Accent
                ValLabel.TextSize        = 12
                ValLabel.TextXAlignment  = Enum.TextXAlignment.Right

                -- Slider track
                local TrackBG = Instance.new("Frame")
                TrackBG.Parent          = el
                TrackBG.BackgroundColor3 = theme.Border
                TrackBG.Position        = UDim2.new(0, 36, 0.5, -2)
                TrackBG.Size            = UDim2.new(1, -100, 0, 4)
                corner(TrackBG, 2)

                local TrackFill = Instance.new("Frame")
                TrackFill.Parent          = TrackBG
                TrackFill.BackgroundColor3 = theme.Accent
                TrackFill.Size            = UDim2.new((defVal - minVal) / (maxVal - minVal), 0, 1, 0)
                corner(TrackFill, 2)

                local Knob = Instance.new("Frame")
                Knob.Parent          = TrackBG
                Knob.BackgroundColor3 = Color3.new(1, 1, 1)
                Knob.AnchorPoint     = Vector2.new(0.5, 0.5)
                Knob.Position        = UDim2.new((defVal - minVal)/(maxVal - minVal), 0, 0.5, 0)
                Knob.Size            = UDim2.fromOffset(12, 12)
                corner(Knob, 6)

                local mouse = game.Players.LocalPlayer:GetMouse()
                local uis   = game:GetService("UserInputService")
                local draggingSlider = false

                local function updateSlider()
                    local pct = math.clamp(
                        (mouse.X - TrackBG.AbsolutePosition.X) / TrackBG.AbsoluteSize.X,
                        0, 1
                    )
                    local val = math.floor(minVal + (maxVal - minVal) * pct)
                    TrackFill.Size = UDim2.new(pct, 0, 1, 0)
                    Knob.Position  = UDim2.new(pct, 0, 0.5, 0)
                    ValLabel.Text  = tostring(val)
                    pcall(callback, val)
                end

                el.MouseButton1Down:Connect(function()
                    if not focusing then
                        draggingSlider = true
                        updateSlider()
                    end
                end)

                local mcon, ucon
                el.MouseButton1Down:Connect(function()
                    if not focusing then
                        mcon = mouse.Move:Connect(function()
                            if draggingSlider then updateSlider() end
                        end)
                        ucon = uis.InputEnded:Connect(function(inp)
                            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                                draggingSlider = false
                                if mcon then mcon:Disconnect() end
                                if ucon then ucon:Disconnect() end
                            end
                        end)
                    end
                end)

                local tooltip = makeTooltip(tip)
                infoBtn.MouseButton1Click:Connect(function() showTooltip(tooltip) end)

                task.spawn(function()
                    while task.wait(0) do
                        TrackBG.BackgroundColor3   = theme.Border
                        TrackFill.BackgroundColor3 = theme.Accent
                        ValLabel.TextColor3        = theme.Accent
                        Knob.BackgroundColor3      = Color3.new(1, 1, 1)
                    end
                end)

                syncSizes()
            end

