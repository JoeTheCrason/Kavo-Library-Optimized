            -- ── Color Picker ─────────────────────────────────────────────────
            function Elements:NewColorPicker(cpName, tip, defColor, callback)
                cpName   = cpName or "Color"
                tip      = tip or ""
                defColor = defColor or Color3.fromRGB(255, 100, 100)
                callback = callback or function() end

                local h, s, v = Color3.toHSV(defColor)
                local colorOpen = false
                local plr = game.Players.LocalPlayer
                local mouse = plr:GetMouse()
                local uis = game:GetService("UserInputService")

                local el, ic, lb, infoBtn = makeBaseElement(
                    "rbxassetid://3926305904",
                    Vector2.new(44, 964), Vector2.new(36, 36)
                )
                lb.Text = cpName
                lb.Size = UDim2.new(0.45, 0, 0, 16)

                -- Color swatch
                local Swatch = Instance.new("Frame")
                Swatch.Parent          = el
                Swatch.BackgroundColor3 = defColor
                Swatch.Position        = UDim2.new(1, -80, 0.5, -10)
                Swatch.Size            = UDim2.fromOffset(48, 20)
                corner(Swatch, 6)
                stroke(Swatch, theme.Border)

                -- Picker panel (expands below)
                local Picker = Instance.new("Frame")
                Picker.Parent          = SecInners
                Picker.BackgroundColor3 = theme.Surface
                Picker.Size            = UDim2.new(1, 0, 0, 0)
                Picker.ClipsDescendants = true
                corner(Picker, 8)

                local SatVal = Instance.new("ImageButton")
                SatVal.Parent          = Picker
                SatVal.BackgroundColor3 = Color3.new(1,1,1)
                SatVal.Position        = UDim2.new(0, 10, 0, 8)
                SatVal.Size            = UDim2.new(0.72, -14, 0, 78)
                SatVal.Image           = "http://www.roblox.com/asset/?id=6523286724"
                SatVal.AutoButtonColor = false
                corner(SatVal, 6)

                local SVCursor = Instance.new("Frame")
                SVCursor.Parent          = SatVal
                SVCursor.BackgroundColor3 = Color3.new(1,1,1)
                SVCursor.Size            = UDim2.fromOffset(12, 12)
                SVCursor.Position        = UDim2.new(s, -6, 1-v, -6)
                corner(SVCursor, 6)
                stroke(SVCursor, Color3.new(0,0,0), 1.5)

                local HueBar = Instance.new("ImageButton")
                HueBar.Parent          = Picker
                HueBar.BackgroundColor3 = Color3.new(1,1,1)
                HueBar.Position        = UDim2.new(0.72, 4, 0, 8)
                HueBar.Size            = UDim2.new(0, 16, 0, 78)
                HueBar.Image           = "http://www.roblox.com/asset/?id=6523291212"
                HueBar.AutoButtonColor = false
                corner(HueBar, 6)

                local HueCursor = Instance.new("Frame")
                HueCursor.Parent          = HueBar
                HueCursor.BackgroundColor3 = Color3.new(1,1,1)
                HueCursor.AnchorPoint     = Vector2.new(0.5, 0)
                HueCursor.Size            = UDim2.fromOffset(16, 8)
                HueCursor.Position        = UDim2.new(0.5, 0, h, -4)
                corner(HueCursor, 4)
                stroke(HueCursor, Color3.new(0,0,0), 1)

                local function updateColor()
                    local realColor = Color3.fromHSV(h, s, v)
                    Swatch.BackgroundColor3 = realColor
                    callback(realColor)
                end

                local svDown, hueDown = false, false

                SatVal.MouseButton1Down:Connect(function() svDown = true end)
                HueBar.MouseButton1Down:Connect(function() hueDown = true end)
                uis.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        svDown, hueDown = false, false
                    end
                end)
                mouse.Move:Connect(function()
                    if svDown then
                        local px = math.clamp((mouse.X - SatVal.AbsolutePosition.X)/SatVal.AbsoluteSize.X, 0, 1)
                        local py = math.clamp((mouse.Y - SatVal.AbsolutePosition.Y)/SatVal.AbsoluteSize.Y, 0, 1)
                        s = px; v = 1 - py
                        SVCursor.Position = UDim2.new(px, -6, py, -6)
                        updateColor()
                    end
                    if hueDown then
                        local py = math.clamp((mouse.Y - HueBar.AbsolutePosition.Y)/HueBar.AbsoluteSize.Y, 0, 1)
                        h = py
                        HueCursor.Position = UDim2.new(0.5, 0, py, -4)
                        updateColor()
                    end
                end)

                el.MouseButton1Click:Connect(function()
                    if not focusing then
                        colorOpen = not colorOpen
                        Picker:TweenSize(
                            colorOpen and UDim2.new(1,0,0,96) or UDim2.new(1,0,0,0),
                            "InOut", "Quart", 0.2, true
                        )
                        task.wait(0.22)
                        syncSizes()
                        task.spawn(ripple, el, theme)
                    end
                end)

                local tooltip = makeTooltip(tip)
                infoBtn.MouseButton1Click:Connect(function() showTooltip(tooltip) end)

                task.spawn(function()
                    while task.wait(0) do
                        Picker.BackgroundColor3 = theme.Surface
                    end
                end)

                syncSizes()
            end

            return Elements
        end
        return Sections
    end

    return Tabs
end

