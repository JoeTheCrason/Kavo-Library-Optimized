            -- ── Dropdown ─────────────────────────────────────────────────────
            function Elements:NewDropdown(dname, tip, list, callback)
                dname    = dname or "Dropdown"
                tip      = tip or ""
                list     = list or {}
                callback = callback or function() end

                local opened = false
                local el, ic, lb, infoBtn = makeBaseElement(
                    "rbxassetid://3926305904",
                    Vector2.new(644, 364), Vector2.new(36, 36)
                )
                lb.Text = dname

                local ChevronImg = Instance.new("ImageLabel")
                ChevronImg.Parent          = el
                ChevronImg.BackgroundTransparency = 1
                ChevronImg.Position        = UDim2.new(1, -52, 0.5, -9)
                ChevronImg.Size            = UDim2.fromOffset(18, 18)
                ChevronImg.Image           = "rbxassetid://3926305904"
                ChevronImg.ImageColor3     = theme.TextMuted
                ChevronImg.ImageRectOffset = Vector2.new(284, 284)
                ChevronImg.ImageRectSize   = Vector2.new(36, 36)

                local OptionList = Instance.new("Frame")
                OptionList.Parent          = SecInners
                OptionList.BackgroundTransparency = 1
                OptionList.Size            = UDim2.new(1, 0, 0, 0)
                OptionList.ClipsDescendants = true

                local OptionLayout = Instance.new("UIListLayout")
                OptionLayout.Parent    = OptionList
                OptionLayout.SortOrder = Enum.SortOrder.LayoutOrder
                OptionLayout.Padding   = UDim.new(0, 3)

                local OptionPad = Instance.new("UIPadding")
                OptionPad.Parent     = OptionList
                OptionPad.PaddingTop = UDim.new(0, 3)

                local function addOption(text)
                    local opt = Instance.new("TextButton")
                    opt.Parent          = OptionList
                    opt.BackgroundColor3 = theme.Element
                    opt.Size            = UDim2.new(1, 0, 0, 32)
                    opt.AutoButtonColor = false
                    opt.Font            = Enum.Font.GothamMedium
                    opt.Text            = "  "..text
                    opt.RichText        = true
                    opt.TextColor3      = theme.TextMuted
                    opt.TextSize        = 12
                    opt.TextXAlignment  = Enum.TextXAlignment.Left
                    corner(opt, 7)

                    opt.MouseEnter:Connect(function()
                        Tween(opt, {BackgroundColor3 = theme.ElementHov, TextColor3 = theme.Text}, 0.1)
                    end)
                    opt.MouseLeave:Connect(function()
                        Tween(opt, {BackgroundColor3 = theme.Element, TextColor3 = theme.TextMuted}, 0.1)
                    end)
                    opt.MouseButton1Click:Connect(function()
                        lb.Text = dname.." → "..text
                        opened = false
                        local cs = OptionLayout.AbsoluteContentSize
                        OptionList:TweenSize(UDim2.new(1,0,0,0), "InOut","Quart",0.18,true)
                        task.wait(0.2)
                        syncSizes()
                        callback(text)
                        task.spawn(ripple, opt, theme)
                    end)
                    task.spawn(function()
                        while task.wait(0) do
                            opt.BackgroundColor3 = theme.Element
                        end
                    end)
                end

                for _, v in ipairs(list) do addOption(v) end

                el.MouseButton1Click:Connect(function()
                    if not focusing then
                        opened = not opened
                        local cs = OptionLayout.AbsoluteContentSize
                        if opened then
                            OptionList:TweenSize(UDim2.new(1,0,0, cs.Y + 6), "InOut","Quart",0.2,true)
                        else
                            OptionList:TweenSize(UDim2.new(1,0,0,0), "InOut","Quart",0.18,true)
                        end
                        task.wait(0.22)
                        syncSizes()
                        task.spawn(ripple, el, theme)
                    end
                end)

                local tooltip = makeTooltip(tip)
                infoBtn.MouseButton1Click:Connect(function() showTooltip(tooltip) end)

                syncSizes()

                local DropFn = {}
                function DropFn:Refresh(newList)
                    for _, v in ipairs(OptionList:GetChildren()) do
                        if v:IsA("TextButton") then v:Destroy() end
                    end
                    for _, v in ipairs(newList) do addOption(v) end
                    if opened then
                        local cs = OptionLayout.AbsoluteContentSize
                        OptionList:TweenSize(UDim2.new(1,0,0, cs.Y + 6), "InOut","Quart",0.1,true)
                        task.wait(0.12)
                        syncSizes()
                    end
                end
                return DropFn
