                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        hueDragging = false
                    end
                end)
                
                return {
                    Set = function(color)
                        ColorPreview.BackgroundColor3 = color
                        local h, s, v = Color3.toHSV(color)
                        hue, sat, val = h, s, v
                        callback(color)
                    end,
                    Get = function()
                        return ColorPreview.BackgroundColor3
                    end
                }
            end
            
            function SectionElements:CreateLabel(config)
                config = config or {}
                local text = config.Text or "Label"
                
                local Label = Utility:Create("TextLabel", {
                    Name = "Label",
                    Parent = Content,
                    Size = UDim2.new(1, 0, 0, 30),
                    BackgroundTransparency = 1,
                    Text = text,
                    Font = Enum.Font.Gotham,
                    TextColor3 = theme.TextSecondary,
                    TextSize = 13,
                    TextWrapped = true,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    LayoutOrder = #Content:GetChildren()
                })
                
                return {
                    Set = function(newText)
                        Label.Text = newText
                    end
                }
            end
            
            return SectionElements
        end
        
        return Elements
    end
    
    -- Global toggle function
    function Tabs:ToggleUI()
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
    
    -- Destroy function
    function Tabs:Destroy()
        ScreenGui:Destroy()
    end
    
    -- Initial animation
    MainFrame.Size = UDim2.new(0, 0, 0, 0)
    MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    
    Utility:Tween(MainFrame, Animations.Elastic, {
        Size = size,
        Position = position
    })
    
    return Tabs
end

-- Notification System
function ModernUI:Notify(config)
    config = config or {}
    local title = config.Title or "Notification"
    local text = config.Text or ""
    local duration = config.Duration or 5
    local type = config.Type or "Info" -- Info, Success, Warning, Error
    
    local theme = Themes.Dark
    
    local colors = {
        Info = theme.Primary,
        Success = theme.Success,
        Warning = theme.Warning,
        Error = theme.Error
    }
    
    local notificationColor = colors[type] or theme.Primary
    
    -- Notification container
    local Notification = Utility:Create("Frame", {
        Name = "Notification",
        Parent = CoreGui,
        Position = UDim2.new(1, -320, 1, -100),
        Size = UDim2.new(0, 300, 0, 80),
        BackgroundColor3 = theme.Surface,
        BorderSizePixel = 0
    })
    
    local NotificationCorner = Utility:Create("UICorner", {
        Parent = Notification,
        CornerRadius = UDim.new(0, 12)
    })
    
    local NotificationStroke = Utility:Create("UIStroke", {
        Parent = Notification,
        Color = notificationColor,
        Thickness = 2
    })
    
    CreateShadow(Notification, 1)
    
    -- Icon
    local iconIds = {
        Info = "rbxassetid://3926305904",
        Success = "rbxassetid://3926305904",
        Warning = "rbxassetid://3926305904",
        Error = "rbxassetid://3926305904"
    }
    
    local NotificationIcon = Utility:Create("ImageLabel", {
        Parent = Notification,
        Position = UDim2.new(0, 15, 0.5, -15),
        Size = UDim2.new(0, 30, 0, 30),
        BackgroundTransparency = 1,
        Image = iconIds[type],
        ImageColor3 = notificationColor
    })
    
    -- Title
    local NotificationTitle = Utility:Create("TextLabel", {
        Parent = Notification,
        Position = UDim2.new(0, 55, 0, 15),
        Size = UDim2.new(1, -70, 0, 20),
        BackgroundTransparency = 1,
        Text = title,
        Font = Enum.Font.GothamBold,
        TextColor3 = theme.TextPrimary,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    -- Text
    local NotificationText = Utility:Create("TextLabel", {
        Parent = Notification,
        Position = UDim2.new(0, 55, 0, 38),
        Size = UDim2.new(1, -70, 0, 30),
        BackgroundTransparency = 1,
        Text = text,
        Font = Enum.Font.Gotham,
        TextColor3 = theme.TextSecondary,
        TextSize = 13,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top
    })
    
    -- Progress bar
    local ProgressBar = Utility:Create("Frame", {
        Parent = Notification,
        Position = UDim2.new(0, 0, 1, -4),
        Size = UDim2.new(1, 0, 0, 4),
        BackgroundColor3 = notificationColor,
        BorderSizePixel = 0
    })
    
    local ProgressCorner = Utility:Create("UICorner", {
        Parent = ProgressBar,
        CornerRadius = UDim.new(0, 2)
    })
    
    -- Animate in
    Notification.Position = UDim2.new(1, 0, 1, -100)
    Utility:Tween(Notification, Animations.Bounce, {
        Position = UDim2.new(1, -320, 1, -100)
    })
    
    -- Progress animation
    Utility:Tween(ProgressBar, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
        Size = UDim2.new(0, 0, 0, 4)
    })
    
    -- Auto remove
    task.delay(duration, function()
        Utility:Tween(Notification, Animations.Normal, {
            Position = UDim2.new(1, 0, 1, -100),
            BackgroundTransparency = 1
        })
        
        for _, child in ipairs(Notification:GetDescendants()) do
            if child:IsA("GuiObject") then
                Utility:Tween(child, Animations.Fast, {Transparency = 1})
            end
        end
        
        task.delay(0.3, function()
            Notification:Destroy()
        end)
    end)
end

return ModernUI
