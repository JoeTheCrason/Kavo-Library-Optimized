                })
                
                local SliderKnob = Utility:Create("Frame", {
                    Name = "Knob",
                    Parent = SliderBar,
                    Position = UDim2.new((default - min) / (max - min), -8, 0.5, -8),
                    Size = UDim2.new(0, 16, 0, 16),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BorderSizePixel = 0
                })
                
                local SliderKnobCorner = Utility:Create("UICorner", {
