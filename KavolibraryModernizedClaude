local function resolveTheme(input)
    if type(input) == "string" then
        return Themes[input] or Themes.Default
    elseif type(input) == "table" then
        local base = {}
        for k, v in pairs(Themes.Default) do base[k] = v end
        for k, v in pairs(input)          do base[k] = v end
        return base
    end
    return Themes.Default
end

-- ── Helpers ───────────────────────────────────────────────────────────────────
local function ripple(parent, theme)
    local ms  = game.Players.LocalPlayer:GetMouse()
    local rip = Instance.new("ImageLabel")
    rip.Parent                 = parent
    rip.BackgroundTransparency = 1
    rip.Image                  = "http://www.roblox.com/asset/?id=4560909609"
    rip.ImageColor3            = theme.Accent
    rip.ImageTransparency      = 0.72
    -- FIX: AnchorPoint(0.5,0.5) so TweenSizeAndPosition expands from the click center
    --      without needing manual -sz/2 offset arithmetic
    rip.AnchorPoint            = Vector2.new(0.5, 0.5)
    rip.Size                   = UDim2.fromOffset(0, 0)
    rip.Position               = UDim2.fromOffset(
        ms.X - parent.AbsolutePosition.X,
        ms.Y - parent.AbsolutePosition.Y
    )
    local sz = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 1.6
    rip:TweenSizeAndPosition(
        UDim2.fromOffset(sz, sz),
        UDim2.new(0.5, 0, 0.5, 0),
        "Out", "Quad", 0.38, true
    )
    for i = 1, 10 do
        rip.ImageTransparency = rip.ImageTransparency + 0.065
        task.wait(0.38 / 12)
    end
    rip:Destroy()
end

local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color           = color
    s.Thickness       = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent          = parent
    return s
end

local LibName = tostring(math.random(1000, 9999)) .. "_KavoMod"

local SavedSettings = {}
pcall(function()
    local name = "KavoModernConfig.json"
    if not pcall(function() readfile(name) end) then
        writefile(name, game:GetService("HttpService"):JSONEncode(SavedSettings))
    end
    SavedSettings = game:GetService("HttpService"):JSONDecode(readfile(name))
end)

function Kavo:ToggleUI()
    local gui = game.CoreGui:FindFirstChild(LibName)
    if gui then gui.Enabled = not gui.Enabled end
end

-- ══════════════════════════════════════════════════════════════════════════════
function Kavo.CreateLib(libName, themeInput)
    libName = libName or "Script"
    local theme = resolveTheme(themeInput)

    for _, v in ipairs(game.CoreGui:GetChildren()) do
        if v:IsA("ScreenGui") and v.Name == LibName then v:Destroy() end
    end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name            = LibName
    ScreenGui.Parent          = game.CoreGui
    ScreenGui.ZIndexBehavior  = Enum.ZIndexBehavior.Sibling
    ScreenGui.ResetOnSpawn    = false
    -- FIX: Disable the 36px GUI inset so Position(0.5,0,0.5,0) truly means screen center
    ScreenGui.IgnoreGuiInset  = true

    -- ── Main window ───────────────────────────────────────────────────────────
    local Main = Instance.new("Frame")
    Main.Name             = "Main"
    Main.Parent           = ScreenGui
    Main.BackgroundColor3 = theme.Background
    -- ClipsDescendants intentionally NOT set here — it would clip UICorner on child frames,
    -- causing the bottom corners of Sidebar/InfoBar to appear square.
    Main.AnchorPoint      = Vector2.new(0.5, 0.5)
    Main.Position         = UDim2.new(0.5, 0, 0.5, 0)
    Main.Size             = UDim2.fromOffset(540, 330)
    corner(Main, 10)
    stroke(Main, theme.Border)

    -- Open animation: scale from zero, AnchorPoint keeps it centered during tween
    Main.Size = UDim2.fromOffset(0, 0)
    Tween(Main, {Size = UDim2.fromOffset(540, 330)}, 0.3)

    -- ── Title bar ─────────────────────────────────────────────────────────────
    local TitleBar = Instance.new("Frame")
    TitleBar.Name             = "TitleBar"
    TitleBar.Parent           = Main
    TitleBar.BackgroundColor3 = theme.Surface
    TitleBar.Size             = UDim2.new(1, 0, 0, 32)
    TitleBar.Position         = UDim2.new(0, 0, 0, 0)
    corner(TitleBar, 10)

    -- Cover the bottom rounded corners of the titlebar
    local TitleCover = Instance.new("Frame")
    TitleCover.Parent             = TitleBar
    TitleCover.BackgroundColor3   = theme.Surface
    TitleCover.BorderSizePixel    = 0
    -- FIX: AnchorPoint(0,1) at Position(0,1,0,0) snaps it flush to the bottom edge
    TitleCover.AnchorPoint        = Vector2.new(0, 1)
    TitleCover.Position           = UDim2.new(0, 0, 1, 0)
    TitleCover.Size               = UDim2.new(1, 0, 0.5, 0)

    -- Bottom divider line
    local TitleDivider = Instance.new("Frame")
    TitleDivider.Name             = "TitleDivider"
    TitleDivider.Parent           = TitleBar
    TitleDivider.BackgroundColor3 = theme.Border
    TitleDivider.BorderSizePixel  = 0
    -- FIX: AnchorPoint(0,1) at Position(0,1,0,0) pins it to the very bottom
    TitleDivider.AnchorPoint      = Vector2.new(0, 1)
    TitleDivider.Position         = UDim2.new(0, 0, 1, 0)
    TitleDivider.Size             = UDim2.new(1, 0, 0, 1)

    -- Accent dot — FIX: AnchorPoint(0,0.5) + Y=0.5 to vertically center in titlebar
    local AccentDot = Instance.new("Frame")
    AccentDot.Parent             = TitleBar
    AccentDot.BackgroundColor3   = theme.Accent
    AccentDot.AnchorPoint        = Vector2.new(0, 0.5)
    AccentDot.Position           = UDim2.new(0, 13, 0.5, 0)
    AccentDot.Size               = UDim2.fromOffset(6, 6)
    corner(AccentDot, 3)

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Parent                 = TitleBar
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Position               = UDim2.new(0, 26, 0, 0)
    TitleLabel.Size                   = UDim2.new(1, -60, 1, 0)
    TitleLabel.Font                   = Enum.Font.GothamMedium
    TitleLabel.Text                   = libName
    TitleLabel.TextColor3             = theme.Text
    TitleLabel.TextSize               = 13
    TitleLabel.TextXAlignment         = Enum.TextXAlignment.Left
    TitleLabel.RichText               = true

    -- Close button — FIX: AnchorPoint(1,0.5) anchors to right-center; no manual -30 offset
    local CloseBtn = Instance.new("ImageButton")
    CloseBtn.Parent           = TitleBar
    CloseBtn.BackgroundColor3 = theme.Element
    CloseBtn.AnchorPoint      = Vector2.new(1, 0.5)
    CloseBtn.Position         = UDim2.new(1, -8, 0.5, 0)
    CloseBtn.Size             = UDim2.fromOffset(22, 22)
    CloseBtn.Image            = "rbxassetid://3926305904"
    CloseBtn.ImageColor3      = theme.TextMuted
    CloseBtn.ImageRectOffset  = Vector2.new(284, 4)
    CloseBtn.ImageRectSize    = Vector2.new(24, 24)
    CloseBtn.AutoButtonColor  = false
    corner(CloseBtn, 6)

    CloseBtn.MouseEnter:Connect(function()
        Tween(CloseBtn, {BackgroundColor3 = Color3.fromRGB(200,50,50), ImageColor3 = Color3.fromRGB(255,255,255)}, 0.15)
    end)
    CloseBtn.MouseLeave:Connect(function()
        Tween(CloseBtn, {BackgroundColor3 = theme.Element, ImageColor3 = theme.TextMuted}, 0.15)
    end)
    CloseBtn.MouseButton1Click:Connect(function()
        -- FIX: Just shrink — AnchorPoint handles centering during the tween
        Tween(Main, {Size = UDim2.fromOffset(0, 0)}, 0.22)
        task.wait(0.25)
        ScreenGui:Destroy()
    end)

    -- Dragging (Position.Scale stays at 0.5; only Offset changes)
    do
        local dragging, dragInput, mousePos, framePos = false
        TitleBar.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                mousePos = inp.Position
                framePos = Main.Position
                inp.Changed:Connect(function()
                    if inp.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        TitleBar.InputChanged:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseMovement then dragInput = inp end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if inp == dragInput and dragging then
                local delta = inp.Position - mousePos
                Main.Position = UDim2.new(
                    framePos.X.Scale, framePos.X.Offset + delta.X,
                    framePos.Y.Scale, framePos.Y.Offset + delta.Y
                )
            end
        end)
    end

    -- ── Sidebar ───────────────────────────────────────────────────────────────
    local Sidebar = Instance.new("Frame")
    Sidebar.Name             = "Sidebar"
    Sidebar.Parent           = Main
    Sidebar.BackgroundColor3 = theme.Surface
    Sidebar.Position         = UDim2.new(0, 0, 0, 32)
    Sidebar.Size             = UDim2.new(0, 148, 1, -32)

    -- Right divider — FIX: AnchorPoint(1,0) + Position(1,0,0,0) pins to right edge
    local SideDivider = Instance.new("Frame")
    SideDivider.Parent             = Sidebar
    SideDivider.BackgroundColor3   = theme.Border
    SideDivider.BorderSizePixel    = 0
    SideDivider.AnchorPoint        = Vector2.new(1, 0)
    SideDivider.Position           = UDim2.new(1, 0, 0, 0)
    SideDivider.Size               = UDim2.new(0, 1, 1, 0)

    local TabContainer = Instance.new("Frame")
    TabContainer.Parent                 = Sidebar
    TabContainer.BackgroundTransparency = 1
    TabContainer.Position               = UDim2.new(0, 8, 0, 8)
    TabContainer.Size                   = UDim2.new(1, -16, 1, -16)

    local TabLayout = Instance.new("UIListLayout")
    TabLayout.Parent    = TabContainer
    TabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    TabLayout.Padding   = UDim.new(0, 3)

    -- ── Pages ─────────────────────────────────────────────────────────────────
    local PagesHolder = Instance.new("Frame")
    PagesHolder.Name                   = "PagesHolder"
    PagesHolder.Parent                 = Main
    PagesHolder.BackgroundTransparency = 1
    PagesHolder.ClipsDescendants       = true   -- clip page scroll content, not the window corners
    PagesHolder.Position               = UDim2.new(0, 148, 0, 32)
    PagesHolder.Size                   = UDim2.new(1, -148, 1, -64)

    -- ── Info bar ──────────────────────────────────────────────────────────────
    local InfoBar = Instance.new("Frame")
    InfoBar.Name             = "InfoBar"
    InfoBar.Parent           = Main
    InfoBar.BackgroundColor3 = theme.Surface
    -- FIX: AnchorPoint(0,1) + Position(0,148,1,0) pins flush to the bottom of Main
    InfoBar.AnchorPoint      = Vector2.new(0, 1)
    InfoBar.Position         = UDim2.new(0, 148, 1, 0)
    InfoBar.Size             = UDim2.new(1, -148, 0, 32)

    local InfoDivider = Instance.new("Frame")
    InfoDivider.Parent             = InfoBar
    InfoDivider.BackgroundColor3   = theme.Border
    InfoDivider.BorderSizePixel    = 0
    InfoDivider.Size               = UDim2.new(1, 0, 0, 1)

    local BlurFrame = Instance.new("Frame")
    BlurFrame.Parent                 = PagesHolder
    BlurFrame.BackgroundColor3       = Color3.new(0, 0, 0)
    BlurFrame.BackgroundTransparency = 1
    BlurFrame.Size                   = UDim2.new(1, 0, 1, 0)
    BlurFrame.ZIndex                 = 50

    -- Theme sync
    task.spawn(function()
        while task.wait(0) do
            Main.BackgroundColor3         = theme.Background
            TitleBar.BackgroundColor3     = theme.Surface
            TitleCover.BackgroundColor3   = theme.Surface
            TitleDivider.BackgroundColor3 = theme.Border
            AccentDot.BackgroundColor3    = theme.Accent
            TitleLabel.TextColor3         = theme.Text
            Sidebar.BackgroundColor3      = theme.Surface
            SideDivider.BackgroundColor3  = theme.Border
            InfoBar.BackgroundColor3      = theme.Surface
            InfoDivider.BackgroundColor3  = theme.Border
        end
    end)

    function Kavo:ChangeColor(key, color)
        if theme[key] ~= nil then theme[key] = color end
    end

    -- ══════════════════════════════════════════════════════════════════════════
    local Tabs     = {}
    local firstTab = true
    local tabOrder = 0

    function Tabs:NewTab(tabName)
        tabName  = tabName or "Tab"
        tabOrder = tabOrder + 1

        local TabBtn = Instance.new("TextButton")
        TabBtn.Parent                = TabContainer
        TabBtn.BackgroundColor3      = theme.Element
        TabBtn.BackgroundTransparency = 1
        TabBtn.Size                  = UDim2.new(1, 0, 0, 30)
        TabBtn.Font                  = Enum.Font.GothamMedium
        TabBtn.Text                  = tabName
        TabBtn.TextColor3            = theme.TextMuted
        TabBtn.TextSize              = 13
        TabBtn.AutoButtonColor       = false
        TabBtn.LayoutOrder           = tabOrder   -- FIX: deterministic sort
        corner(TabBtn, 7)

        -- Active indicator bar — FIX: AnchorPoint(0,0.5) centers it vertically
        local TabIndicator = Instance.new("Frame")
        TabIndicator.Parent                 = TabBtn
        TabIndicator.BackgroundColor3       = theme.Accent
        TabIndicator.BackgroundTransparency = 1
        TabIndicator.BorderSizePixel        = 0
        TabIndicator.AnchorPoint            = Vector2.new(0, 0.5)
        TabIndicator.Position               = UDim2.new(0, 0, 0.5, 0)
        TabIndicator.Size                   = UDim2.new(0, 3, 0, 0)
        corner(TabIndicator, 2)

        local Page = Instance.new("ScrollingFrame")
        Page.Name                  = "Page_"..tabName
        Page.Parent                = PagesHolder
        Page.BackgroundTransparency = 1
        Page.BorderSizePixel       = 0
        Page.Size                  = UDim2.new(1, 0, 1, 0)
        Page.ScrollBarThickness    = 3
        Page.ScrollBarImageColor3  = theme.ScrollBar
        Page.ScrollingDirection    = Enum.ScrollingDirection.Y
        Page.CanvasSize            = UDim2.fromOffset(0, 0)
        Page.Visible               = false

        local PageLayout = Instance.new("UIListLayout")
        PageLayout.Parent    = Page
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        PageLayout.Padding   = UDim.new(0, 6)

        local PagePadding = Instance.new("UIPadding")
        PagePadding.Parent        = Page
        PagePadding.PaddingTop    = UDim.new(0, 10)
        PagePadding.PaddingLeft   = UDim.new(0, 10)
        PagePadding.PaddingRight  = UDim.new(0, 10)

        local function updateCanvas()
            Page.CanvasSize = UDim2.fromOffset(0, PageLayout.AbsoluteContentSize.Y + 20)
        end
        PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)

        local function activateTab()
            for _, pg in ipairs(PagesHolder:GetChildren()) do
                if pg:IsA("ScrollingFrame") then pg.Visible = false end
            end
            for _, btn in ipairs(TabContainer:GetChildren()) do
                if btn:IsA("TextButton") then
                    Tween(btn, {TextColor3 = theme.TextMuted, BackgroundTransparency = 1}, 0.18)
                    local ind = btn:FindFirstChildOfClass("Frame")
                    if ind then Tween(ind, {BackgroundTransparency = 1, Size = UDim2.new(0,3,0,0)}, 0.18) end
                end
            end
            Page.Visible = true
            Tween(TabBtn, {TextColor3 = theme.Text, BackgroundTransparency = 0.85}, 0.18)
            Tween(TabIndicator, {BackgroundTransparency = 0, Size = UDim2.new(0,3,0.6,0)}, 0.2)
        end

        if firstTab then
            firstTab = false
            activateTab()
        end

        TabBtn.MouseButton1Click:Connect(activateTab)
        TabBtn.MouseEnter:Connect(function()
            if TabBtn.BackgroundTransparency > 0.5 then Tween(TabBtn, {BackgroundTransparency = 0.92}, 0.12) end
        end)
        TabBtn.MouseLeave:Connect(function()
            if TabBtn.BackgroundTransparency > 0.5 then Tween(TabBtn, {BackgroundTransparency = 1}, 0.12) end
        end)
        task.spawn(function()
            while task.wait(0) do
                TabBtn.BackgroundColor3       = theme.Element
                TabIndicator.BackgroundColor3 = theme.Accent
                Page.ScrollBarImageColor3     = theme.ScrollBar
            end
        end)

        local Sections = {}
        local secOrder  = 0

        function Sections:NewSection(secName, hidden)
            secName  = secName or "Section"
            hidden   = hidden or false
            secOrder = secOrder + 1

            local SectionFrame = Instance.new("Frame")
            SectionFrame.Parent                 = Page
            SectionFrame.BackgroundTransparency = 1
            SectionFrame.Size                   = UDim2.new(1, 0, 0, 0)
            SectionFrame.LayoutOrder            = secOrder  -- FIX: explicit order

            local SecLayout = Instance.new("UIListLayout")
            SecLayout.Parent    = SectionFrame
            SecLayout.SortOrder = Enum.SortOrder.LayoutOrder
            SecLayout.Padding   = UDim.new(0, 4)

            -- FIX: LayoutOrder = 1 guarantees header always appears above element container
            local SecHeader = Instance.new("Frame")
            SecHeader.Name                   = "SecHeader"
            SecHeader.Parent                 = SectionFrame
            SecHeader.BackgroundColor3       = theme.Accent
            SecHeader.BackgroundTransparency = 0.88
            SecHeader.Size                   = UDim2.new(1, 0, 0, 26)
            SecHeader.Visible                = not hidden
            SecHeader.LayoutOrder            = 1
            corner(SecHeader, 7)

            -- FIX: AnchorPoint(0,0.5) vertically centers the bar — no manual Y offset
            local SecAccentBar = Instance.new("Frame")
            SecAccentBar.Parent             = SecHeader
            SecAccentBar.BackgroundColor3   = theme.Accent
            SecAccentBar.BorderSizePixel    = 0
            SecAccentBar.AnchorPoint        = Vector2.new(0, 0.5)
            SecAccentBar.Position           = UDim2.new(0, 0, 0.5, 0)
            SecAccentBar.Size               = UDim2.new(0, 3, 0, 0)
            corner(SecAccentBar, 2)
            Tween(SecAccentBar, {Size = UDim2.new(0, 3, 0.65, 0)}, 0.25)

            local SecLabel = Instance.new("TextLabel")
            SecLabel.Parent                 = SecHeader
            SecLabel.BackgroundTransparency = 1
            SecLabel.Position               = UDim2.new(0, 12, 0, 0)
            SecLabel.Size                   = UDim2.new(1, -12, 1, 0)
            SecLabel.Font                   = Enum.Font.GothamMedium
            SecLabel.Text                   = secName
            SecLabel.RichText               = true
            SecLabel.TextColor3             = theme.Text
            SecLabel.TextSize               = 12
            SecLabel.TextXAlignment         = Enum.TextXAlignment.Left

            -- FIX: LayoutOrder = 2 guarantees element container always appears below header
            local SecInners = Instance.new("Frame")
            SecInners.Parent                 = SectionFrame
            SecInners.BackgroundTransparency = 1
            SecInners.Size                   = UDim2.new(1, 0, 0, 0)
            SecInners.LayoutOrder            = 2

            local InnerLayout = Instance.new("UIListLayout")
            InnerLayout.Parent    = SecInners
            InnerLayout.SortOrder = Enum.SortOrder.LayoutOrder
            InnerLayout.Padding   = UDim.new(0, 4)

            local function syncSizes()
                SecInners.Size    = UDim2.new(1, 0, 0, InnerLayout.AbsoluteContentSize.Y)
                SectionFrame.Size = UDim2.new(1, 0, 0, SecLayout.AbsoluteContentSize.Y)
                updateCanvas()
            end
            InnerLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(syncSizes)

            task.spawn(function()
                while task.wait(0) do
                    SecHeader.BackgroundColor3    = theme.Accent
                    SecAccentBar.BackgroundColor3 = theme.Accent
                    SecLabel.TextColor3           = theme.Text
                end
            end)

            local focusing  = false
            local viewDelay = false

            local function showTooltip(label)
                if viewDelay then return end
                viewDelay = true
