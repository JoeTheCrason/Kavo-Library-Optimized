                    end
                    if not silent then pcall(callback, state) end
                end

                el.MouseButton1Click:Connect(function()
                    if not focusing then setToggle(not toggled); task.spawn(ripple, el, theme)
                    else Tween(BlurFrame, {BackgroundTransparency = 1}, 0.15); focusing = false end
                end)
                local tooltip = makeTooltip(tip)
