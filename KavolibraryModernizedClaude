                    Knob.Position  = UDim2.new(pct, 0, 0.5, 0)
                    ValLabel.Text  = tostring(math.floor(minVal + range * pct))
                    pcall(callback, math.floor(minVal + range * pct))
                end

                el.MouseButton1Down:Connect(function()
                    if not focusing then
