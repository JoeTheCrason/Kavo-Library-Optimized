--[[
    Kavo UI Library — Modernized (Positioning Fixed)
    Fixes applied:
      - All centering now uses AnchorPoint instead of manual offset math
      - LayoutOrder set on all UIListLayout children
      - Icon/label/button vertical centering uses AnchorPoint(0, 0.5)
      - Close button / right-anchored elements use AnchorPoint(1, 0.5)
      - Ripple uses AnchorPoint(0.5, 0.5) — no manual -sz/2 needed
      - ScreenGui.IgnoreGuiInset = true to prevent 36px top shift
      - SectionFrame children have explicit LayoutOrder (header=1, inners=2)
      - All UIListLayout children have explicit LayoutOrder counters
--]]

local Kavo = {}

local TweenService     = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local function Tween(obj, props, t, style, dir)
    style = style or Enum.EasingStyle.Quart
    dir   = dir   or Enum.EasingDirection.Out
    TweenService:Create(obj, TweenInfo.new(t, style, dir), props):Play()
end

