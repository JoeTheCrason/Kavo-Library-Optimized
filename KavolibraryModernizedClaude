                    end
                    if hueDown then
                        local py = math.clamp((mouse.Y - HueBar.AbsolutePosition.Y)/HueBar.AbsoluteSize.Y, 0, 1)
                        h = py
                        HueCursor.Position = UDim2.new(0.5, 0, py, 0)  -- FIX: no manual offset
                        updateColor()
                    end
                end)

                el.MouseButton1Click:Connect(function()
                    if not focusing then
                        colorOpen = not colorOpen
                        Picker:TweenSize(colorOpen and UDim2.new(1,0,0,96) or UDim2.new(1,0,0,0), "InOut","Quart",0.2,true)
                        task.wait(0.22); syncSizes(); task.spawn(ripple, el, theme)
                    end
                end)
                local tooltip = makeTooltip(tip)
                infoBtn.MouseButton1Click:Connect(function() showTooltip(tooltip) end)
                task.spawn(function() while task.wait(0) do Picker.BackgroundColor3 = theme.Surface end end)
                syncSizes()
            end

            return Elements
        end
        return Sections
    end
    return Tabs
end

return Kavo
